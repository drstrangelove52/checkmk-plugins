#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Vectra Special Agent  –  agent_vectra_sensors
Holt Sensor-Healthdaten vom Vectra Brain REST API
und schreibt sie als Checkmk Agent-Section in stdout.

Aufruf durch Checkmk:
  agent_vectra_sensors --brain <host> --token <token> [--no-verify-ssl]
"""

import sys
import json
import argparse
import urllib.request
import urllib.error
import ssl


def get_sensors(brain_host: str, api_token: str, verify_ssl: bool = True) -> list[dict]:
    url = f"https://{brain_host}/api/v2.5/health/sensors"
    req = urllib.request.Request(
        url,
        headers={
            "Authorization": f"Token {api_token}",
            "Accept": "application/json",
        },
    )
    ctx = ssl.create_default_context()
    if not verify_ssl:
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE

    with urllib.request.urlopen(req, context=ctx, timeout=30) as resp:
        if resp.status != 200:
            raise RuntimeError(f"HTTP {resp.status} von Brain erhalten")
        data = json.loads(resp.read().decode("utf-8"))

    sensors = data.get("sensors", data if isinstance(data, list) else [])
    return sensors


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Vectra Special Agent – Sensor Health via Brain API",
    )
    parser.add_argument("--brain",          required=True,  metavar="HOST",  help="Brain Hostname/IP")
    parser.add_argument("--token",          required=True,  metavar="TOKEN", help="API Token")
    parser.add_argument("--no-verify-ssl",  action="store_true",             help="SSL-Prüfung deaktivieren")
    args = parser.parse_args()

    try:
        sensors = get_sensors(
            brain_host=args.brain,
            api_token=args.token,
            verify_ssl=not args.no_verify_ssl,
        )
    except urllib.error.HTTPError as e:
        sys.stderr.write(
            f"HTTP-Fehler {e.code} beim Abruf von Brain '{args.brain}': {e.reason}\n"
        )
        if e.code == 401:
            sys.stderr.write("  → API-Token ungültig oder abgelaufen.\n")
        elif e.code == 403:
            sys.stderr.write("  → Fehlende Berechtigung (Detect view health erforderlich).\n")
        return 1
    except urllib.error.URLError as e:
        sys.stderr.write(
            f"Verbindungsfehler zu Brain '{args.brain}': {e.reason}\n"
            "  → Hostname/IP prüfen und sicherstellen, dass der Brain erreichbar ist.\n"
        )
        return 1
    except TimeoutError:
        sys.stderr.write(f"Timeout beim Verbindungsaufbau zu Brain '{args.brain}'.\n")
        return 1
    except Exception as e:
        sys.stderr.write(f"Unerwarteter Fehler: {e}\n")
        return 1

    if not sensors:
        sys.stderr.write(f"Keine Sensoren in der API-Antwort von Brain '{args.brain}'.\n")

    print("<<<vectra_sensors:sep(0)>>>")
    print(json.dumps(sensors))
    return 0


if __name__ == "__main__":
    sys.exit(main())
