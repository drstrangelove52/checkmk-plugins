#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Vectra Special Agent  –  agent_vectra_sensors
Fetches sensor health data from the Vectra Brain REST API
and writes it as a Checkmk agent section to stdout.

Usage by Checkmk:
  agent_vectra_sensors --brain <host> --token <token> [--port <port>] [--timeout <sec>] [--no-verify-ssl]
"""

import sys
import json
import argparse
import urllib.request
import urllib.error
import ssl


def get_sensors(
    brain_host: str,
    api_token: str,
    verify_ssl: bool = True,
    timeout: int = 30,
    port: int | None = None,
) -> list[dict]:
    host_part = f"{brain_host}:{port}" if port else brain_host
    url       = f"https://{host_part}/api/v3.4/health"

    req = urllib.request.Request(
        url,
        headers={
            "Authorization": f"Token {api_token}",
            "Accept": "application/json",
        },
    )

    ctx = ssl.create_default_context()
    if not verify_ssl:
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE

    with urllib.request.urlopen(req, context=ctx, timeout=timeout) as resp:
        data = json.loads(resp.read().decode("utf-8"))

    sensors = data.get("sensors", data if isinstance(data, list) else [])
    return sensors


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Vectra Special Agent – Sensor Health via Brain API",
    )
    parser.add_argument("--brain",         required=True,  metavar="HOST",  help="Brain hostname or IP")
    parser.add_argument("--token",         required=True,  metavar="TOKEN", help="API token")
    parser.add_argument("--port",          type=int, default=None, metavar="PORT", help="Brain API port (default: 443)")
    parser.add_argument("--timeout",       type=int, default=30,  metavar="SEC",  help="Request timeout in seconds (default: 30)")
    parser.add_argument("--no-verify-ssl", action="store_true",                   help="Disable SSL certificate verification")
    args = parser.parse_args()

    try:
        sensors = get_sensors(
            brain_host=args.brain,
            api_token=args.token,
            verify_ssl=not args.no_verify_ssl,
            timeout=args.timeout,
            port=args.port,
        )
    except urllib.error.HTTPError as e:
        sys.stderr.write(
            f"HTTP error {e.code} fetching from Brain '{args.brain}': {e.reason}\n"
        )
        if e.code == 401:
            sys.stderr.write("  → API token is invalid or expired.\n")
        elif e.code == 403:
            sys.stderr.write("  → Insufficient permissions (Detect view health required).\n")
        return 1
    except urllib.error.URLError as e:
        sys.stderr.write(
            f"Connection error to Brain '{args.brain}': {e.reason}\n"
            "  → Check hostname/IP and ensure the Brain is reachable.\n"
        )
        return 1
    except TimeoutError:
        sys.stderr.write(f"Timeout after {args.timeout}s connecting to Brain '{args.brain}'.\n")
        return 1
    except Exception as e:
        sys.stderr.write(f"Unexpected error: {e}\n")
        return 1

    if not sensors:
        sys.stderr.write(f"No sensors found in API response from Brain '{args.brain}'.\n")

    print("<<<vectra_sensors:sep(0)>>>")
    print(json.dumps(sensors))
    return 0


if __name__ == "__main__":
    sys.exit(main())
